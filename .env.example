# Appwrite Configuration
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT=your-project-id
APPWRITE_API_KEY=your-api-key
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_MATCHES_COLLECTION_ID=your-matches-collection-id
APPWRITE_PLAYERS_COLLECTION_ID=your-players-collection-id
APPWRITE_PROFILE_PICTURES_BUCKET_ID=your-profile-pictures-bucket-id

# Authentication
NEXT_PUBLIC_APPWRITE_SESSION_SECRET=your-session-secret

# Logging Configuration
# LOG_LEVEL can be: debug, info, warn, error, silent
# Default: debug in development, error in production
LOG_LEVEL=debug